# LLM / OpenAI-compatible settings
# OPENAI_API_KEY is required when using OpenAI directly, or when LiteLLM auth is enabled.
OPENAI_API_KEY=your_openai_api_key_here
# Model name understood by your provider or gateway (e.g. gpt-4o-mini, claude-3-5-sonnet, gemini-2.0-flash)
OPENAI_MODEL=gpt-4-turbo-preview
# Optional: OpenAI-compatible gateway base URL (LiteLLM/OpenRouter/local vLLM, etc.)
# Example: OPENAI_BASE_URL=http://litellm:4000/v1
# OPENAI_BASE_URL=
# Optional: max tokens for optimization suggestions
# OPENAI_OPTIMIZATION_MAX_TOKENS=1800

# Optional provider keys for LiteLLM multi-provider routing
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
# Bedrock (optional, for LiteLLM Bedrock routing)
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_SESSION_TOKEN=your_aws_session_token
# AWS_REGION=us-east-1
# Optional: enable LiteLLM auth (if set, OPENAI_API_KEY should match this)
# LITELLM_MASTER_KEY=sk-litellm-local

# Application
APP_NAME=Kubeast
APP_VERSION=1.0.0
DEBUG=true

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# WebSocket
WS_HEARTBEAT_INTERVAL=30

# Auth/JWT
JWT_ISSUER=kubeast-auth
JWT_AUDIENCE=kubeast
JWT_EXPIRES_MINUTES=10080
# Auth JWKS URL (used by ai-service/k8s-service/session-service)
# AUTH_JWKS_URL=http://auth-service:8004/api/v1/auth/jwks.json
# Auth cookie name used for browser streaming/WS
# AUTH_COOKIE_NAME=kubeast.token

# Bootstrap admin (auth-service)
# 프로덕션에서는 절대 기본값을 그대로 쓰지 마세요. helm 설치는 자동으로 랜덤 생성합니다.
DEFAULT_ADMIN_EMAIL=admin
DEFAULT_ADMIN_PASSWORD=change-me-do-not-use-in-prod

# Password hashing iterations (auth-service)
# PASSWORD_HASH_ITERATIONS=210000

# Key storage (auth-service, dev)
KEY_DIR=/app/.keys

# Database
POSTGRES_USER=kubeast
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=kubeast
# Optional: full DB URL override (used when running services directly)
# DATABASE_URL=postgresql+asyncpg://kubeast:your_postgres_password_here@localhost:5432/kubeast

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Optional: full Redis URL (compose passes this to ai-service)
# REDIS_URL=redis://redis:6379/0

# Deployment mode: "docker" (docker-compose) or "k8s" (helm/kind).
# docker-compose.yml already sets this per-service; override here only when
# running services directly outside compose.
# DEPLOYMENT_MODE=docker

# Kubernetes
# 로컬에서 직접 실행 시: 사용자 환경에 맞는 kubeconfig 경로
# docker-compose 사용 시: install-docker.sh 가 자동으로 ./kubeconfig.yaml 을 컨테이너에 마운트
KUBECONFIG_PATH=./kubeconfig.yaml
IN_CLUSTER=false
# Docker mode: path inside the shared named volume where auth-service writes
# the kubeconfig submitted via UI, and where k8s-service/tool-server read it.
# DOCKER_KUBECONFIG_PATH=/kubeconfig/kubeconfig.yaml
# Enable fsnotify-based hot-reload of the kubeconfig clientset (docker mode).
# KUBECONFIG_WATCH=true

# Optional: service URLs (currently hardcoded in ai-service)
# K8S_SERVICE_URL=http://k8s-service:8002/api/v1
# SESSION_SERVICE_URL=http://session-service:8003/api/v1
# TOOL_SERVER_URL=http://tool-server:8086

# Frontend (optional if you run frontend outside docker-compose)
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000

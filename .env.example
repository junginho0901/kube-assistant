# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Kubernetes
KUBECONFIG_PATH=/Users/okestro/AgentForCMP/kubeconfig.yaml
IN_CLUSTER=false

# Application
APP_NAME=K8s DevOps Assistant
APP_VERSION=1.0.0
DEBUG=true

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# WebSocket
WS_HEARTBEAT_INTERVAL=30
